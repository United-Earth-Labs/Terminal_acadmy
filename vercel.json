{
    "version": 2,
    "builds": [
        {
            "src": "vercel_wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.11"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/staticfiles/$1"
        },
        {
            "src": "/media/(.*)",
            "dest": "/media/$1"
        },
        {
            "src": "/(.*)",
            "dest": "vercel_wsgi.py"
        }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "core.settings.vercel"
    }
}
