{
    "version": 2,
    "buildCommand": "bash build.sh",
    "build": {
        "env": {
            "DJANGO_SETTINGS_MODULE": "core.settings.vercel",
            "DEBUG": "False"
        }
    },
    "env": {
        "DJANGO_SETTINGS_MODULE": "core.settings.vercel",
        "DEBUG": "False"
    },
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/staticfiles/$1"
        },
        {
            "src": "/media/(.*)",
            "dest": "/media/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.py"
        }
    ]
}
